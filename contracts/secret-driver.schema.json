{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fde-toolkit.com/contracts/secret-driver.schema.json",
  "title": "FDE-Toolkit Secret Broker Contract",
  "description": "References secrets without moving raw values through the SaaS control plane or durable job records.",
  "type": "object",
  "$defs": {
    "leaseRequest": {
      "type": "object",
      "required": ["contractVersion", "tenantId", "jobId", "references", "ttlSeconds"],
      "properties": {
        "contractVersion": { "const": "1.0" },
        "tenantId": { "type": "string", "minLength": 1 },
        "jobId": { "type": "string", "minLength": 8 },
        "references": {
          "type": "object",
          "propertyNames": { "pattern": "^[A-Z][A-Z0-9_]{0,127}$" },
          "additionalProperties": {
            "type": "string",
            "pattern": "^(env|vault|aws-sm|azure-kv)://"
          },
          "maxProperties": 50
        },
        "ttlSeconds": { "type": "integer", "minimum": 30, "maximum": 3600 }
      },
      "additionalProperties": false
    },
    "leaseMetadata": {
      "type": "object",
      "required": ["contractVersion", "leaseId", "tenantId", "jobId", "environmentKeys", "issuedAt", "expiresAt"],
      "properties": {
        "contractVersion": { "const": "1.0" },
        "leaseId": { "type": "string" },
        "tenantId": { "type": "string" },
        "jobId": { "type": "string" },
        "environmentKeys": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "sources": { "type": "array", "items": { "type": "string" } },
        "issuedAt": { "type": "string", "format": "date-time" },
        "expiresAt": { "type": "string", "format": "date-time" },
        "revokedAt": { "type": ["string", "null"], "format": "date-time" }
      },
      "additionalProperties": false
    }
  },
  "oneOf": [{ "$ref": "#/$defs/leaseRequest" }, { "$ref": "#/$defs/leaseMetadata" }]
}
